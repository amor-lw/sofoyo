{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "legacyId": {
      "type": "integer",
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "code": {
      "type": "string"
    },
    "summary": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "legacyCoverPath": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "products"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "specNl": {
      "type": "string"
    },
    "specWg": {
      "type": "string"
    },
    "specXj": {
      "type": "string"
    },
    "specKg": {
      "type": "string"
    },
    "specCh": {
      "type": "string"
    },
    "hits": {
      "type": "integer",
      "default": 0
    },
    "publishedAtLegacy": {
      "type": "datetime"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    }
  }
}
