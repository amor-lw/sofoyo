{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "news",
    "pluralName": "news-items",
    "displayName": "News"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "legacyId": {
      "type": "integer",
      "unique": true,
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "legacyCoverPath": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::news-category.news-category",
      "inversedBy": "newsItems"
    },
    "hits": {
      "type": "integer",
      "default": 0
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "publishedAtLegacy": {
      "type": "datetime"
    },
    "legacySort": {
      "type": "integer",
      "default": 0
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    }
  }
}
