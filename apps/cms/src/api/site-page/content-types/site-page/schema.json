{
  "kind": "collectionType",
  "collectionName": "site_pages",
  "info": {
    "singularName": "site-page",
    "pluralName": "site-pages",
    "displayName": "Site Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "key": {
      "type": "uid",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "heroImage": {
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "content": {
      "type": "richtext"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo"
    }
  }
}
