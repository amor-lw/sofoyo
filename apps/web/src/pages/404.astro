---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout title="页面不存在 | sofoyo" description="404">
  <section class="shell section not-found">
    <p class="section-heading__eyebrow">404</p>
    <h1>页面不存在</h1>
    <p>当前路由尚未配置，或对应 CMS 内容尚未导入。</p>
    <a class="card__link" href="/">返回首页</a>
  </section>
</BaseLayout>
