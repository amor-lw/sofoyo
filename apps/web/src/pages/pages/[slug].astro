---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import RichTextBlock from '../../components/RichTextBlock.astro';
import { getSitePageBySlug, resolveImage, resolveMediaUrl } from '../../lib/api';
import { getPageSectionNav } from '../../lib/site';

const slug = Astro.params.slug || '';
const page = await getSitePageBySlug(slug);

if (!page) {
  return Astro.redirect('/404');
}

const sectionNav = getPageSectionNav(slug);
const gallery = page.gallery || [];
const heroImageOverrides: Record<string, string> = {
  workshop: '/legacy-assets/image/aboutpic.jpg',
  'service-join': '/legacy-assets/image/servicepic.jpg'
};
const heroImage = heroImageOverrides[slug] || resolveImage(page.heroImage);
---

<BaseLayout title={`${page.title} | sofoyo`} description={page.seo?.description || page.title}>
  <PageHero eyebrow="Site Page" title={page.title} description="企业信息" image={heroImage} />
  {sectionNav.length > 0 && (
    <section class="shell section section--compact">
      <div class="section-nav">
        {sectionNav.map((item) => (
          <a class:list={['section-nav__item', item.href === `/pages/${slug}` && 'is-active']} href={item.href}>
            {item.label}
          </a>
        ))}
      </div>
    </section>
  )}
  {slug === 'honor' && gallery.length > 0 && (
    <section class="shell section section--compact">
      <div class="section-heading">
        <p class="section-heading__eyebrow">Honor Gallery</p>
        <h2>企业荣誉图集</h2>
      </div>
      <div class="media-grid">
        {gallery.map((item) => (
          <figure class="media-card">
            <img src={resolveMediaUrl(item.url)} alt={item.alternativeText || item.name || page.title} loading="lazy" />
          </figure>
        ))}
      </div>
    </section>
  )}
  <section class="shell section">
    <RichTextBlock html={page.content || '<p>页面内容待导入。</p>'} />
  </section>
</BaseLayout>
